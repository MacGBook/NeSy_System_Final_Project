# MOCKING
# Here, we obtain the mocking scores. 
with open("mocking_count_output.txt", "r") as f:
    text = f.read()
# extract (name, value) pairs
pairs = re.findall(r"\((\d+),\s*([0-9.]+)\)", text)
data = [(int(n), float(y)) for n, y in pairs]
# compute normalization
values = [y for _, y in data]
total = sum(values)
# build dictionary: name -> normalized score
mocking_score = {n: y / total for n, y in data}
#print(mocking_score.keys())

for score in mocking_score.keys():
    int_list.remove(score)

# print(int_list) # these are now values we need to be zero

for what_to_add in int_list:
    mocking_score[what_to_add] = 0.0

final_mocking_dict = dict(sorted(mocking_score.items()))

#print(final_mocking_dict)

