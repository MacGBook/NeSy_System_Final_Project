# OBTAIN ID LIST

values = []

with open("test_negative.csv", "r") as file:
    reader = csv.reader(file)

    next(reader)  # skip header row

    for row in reader:
        values.append(float(row[0]))  # column 1 = "negative"

int_list = []
name_int_list = []
list_for_questioning = []

for value in values:
    new_value = int(value)
    int_list.append(new_value)
    name_int_list.append(new_value)
    list_for_questioning.append(value)
    

