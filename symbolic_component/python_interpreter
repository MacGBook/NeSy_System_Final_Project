# BELEIF 

import ast

def parse_belief_file(filepath):
    with open(filepath, "r") as f:
        text = f.read()

    # extract everything inside the first {...}
    match = re.search(r"\{.*\}", text)
    if not match:
        raise ValueError("No dictionary-like structure found in file.")

    data_str = match.group()

    # safely evaluate into Python set of tuples
    data = ast.literal_eval(data_str)

    # convert to dictionary
    return dict(data)


first_result = parse_belief_file("first_belief_score_output.txt")
# we leave this first results as is

#####################

def parse_tuple_text(filename):
    with open(filename, "r") as f:
        text = f.read().strip()

    # Split "key: value"
    _, value_str = text.split(":", 1)

    # Safely parse the set of tuples
    raw_data = ast.literal_eval(value_str.strip())

    # Build dictionary: {first_value: [second, third]}
    result = {
        int(item[0]): [float(item[1]), float(item[2])]
        for item in raw_data
        if len(item) == 3
    }

    return result

second_result = parse_tuple_text("second_belief_score_output.txt")

list_of_results = []
for little_list in second_result.values():
    pos_value = little_list[1]
    neg_value = little_list[0]
    score = pos_value - neg_value
    if score >= 0:
        flipped = -score
    else:
        flipped = abs(score)
    # we flip the sign due to sarcasm being present
    list_of_results.append(flipped)

second_dict = dict(zip(second_result.keys(), list_of_results))
# print(second_dict)

#####################

third_result = parse_tuple_text("third_belief_score_output.txt")

third_list_of_results = []
for little_list in third_result.values():
    pos_value = little_list[1]
    neg_value = little_list[0]
    score = pos_value - neg_value
    third_list_of_results.append(score)

third_dict = dict(zip(third_result.keys(), third_list_of_results))
# print(third_dict)

first_result.update(second_dict)
first_result.update(third_dict)

beleif_score_dict = dict(sorted(first_result.items()))
#print(beleif_score_dict)

##################################################################
# Calculate Disbeleif Values

disbelief_values = []
for belief in beleif_score_dict.values():
    if belief >= 0:
        disbelief_value = 1 - belief
    else:
        disbelief_value = -1 - belief
    disbelief_values.append(disbelief_value)

#print(disbelief_values)

