# Calculate Questioning Score

def parse_tuple_text_again(filename):
    with open(filename, "r") as f:
        text = f.read().strip()

    # Split "key: value"
    _, value_str = text.split(":", 1)

    # Safely parse the set of tuples
    raw_data = ast.literal_eval(value_str.strip())

    # Build dictionary: {first_value: [second, third, fourth]}
    result = {
        int(item[0]): [float(item[1]), float(item[2]), float(item[3])]
        for item in raw_data
        if len(item) == 4
    }

    return result

questioning_result = parse_tuple_text_again("questioning_output.txt")
#print(questioning_result)

non_norm_scores = []
for val in list(questioning_result.values()):
    neutral = val[0]
    positive = val[2]
    negative = val[1]
    score = positive - negative
    combined = neutral + score
    non_norm_scores.append(combined)

denom = sum(non_norm_scores)

normalized_scores = []
for val in non_norm_scores:
    fract = val / denom
    normalized_scores.append(fract)

#print(normalized_scores)
#print(list(questioning_result.keys()))

final_dict = {}
for iter in range(len(normalized_scores)):
    valuee = normalized_scores[iter]
    keyy = (list(questioning_result.keys()))[iter]
    final_dict[keyy] = valuee

#print(final_dict)

for value in list(final_dict.keys()):
    list_for_questioning.remove(value)

#print(list_for_questioning)

for value in list_for_questioning:
    final_dict[value] = 0.0

questioning_dict_final = dict(sorted(final_dict.items()))

print(questioning_dict_final)

